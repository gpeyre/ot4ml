xSW":{"macro":"\\operatorname{MaxSW}"},"\\SRW":{"macro":"\\operatorname{SRW}"},"\\LOT":{"macro":"\\operatorname{LOT}"},"\\WOT":{"macro":"\\operatorname{WOT}"},"\\GW":{"macro":"\\mathcal{GW}"},"\\GWD":{"macro":"\\mathrm{GW}"},"\\Laguerre":{"macro":"\\mathbb{L}"},"\\Qq":{"macro":"\\mathcal{Q}"},"\\Ss":{"macro":"\\mathcal{S}"},"\\De":{"macro":"\\Delta"},"\\XX":{"macro":"\\mathbb{X}"},"\\YY":{"macro":"\\mathbb{Y}"},"\\it":{"macro":"#1^{(\\ell)}"},"\\itt":{"macro":"#1^{(\\ell+1)}"}},"exports":[{"format":"md","filename":"conclusion.md","url":"/ot4ml/myst/_build/html/build/conclusion-f8320d12e030cb39eff29e88bf08eba9.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Optimal transport is useful because it keeps several viewpoints active at\nonce. It is a linear program over couplings, a duality theory for potentials,\na geometry on probability measures, a source of PDEs and gradient flows, and a\ncomputational toolbox built around linear programming, Sinkhorn scaling and\nlow-dimensional projections. These viewpoints reinforce each other: Brenier\nmaps explain geodesics, geodesic convexity explains convergence of flows,\nentropic regularization turns transport into scalable differentiable losses,\nand dual norms or sliced variants reveal what is gained and lost when OT is\nsimplified.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"WG4fdiVLCH"}],"key":"i1e8a2Goq2"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"For machine learning, this interplay is especially stimulating. Modern\ngenerative modeling, diffusion and flow matching, inverse problems, robust\noptimization, and even continuous-depth views of transformers all ask for ways\nto move, compare or learn distributions in high dimension. These applications\ndo not merely consume existing OT theory; they create difficult mathematical\nquestions because empirical measures are singular, dimensions are large,\nmodels are parametrized and non-convex, and computational approximations are\ninseparable from statistical error. The strength of OT is precisely that it\ngives a common language for these tensions, while still leaving enough open\nstructure for new mathematics to be needed.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"f8vnjNWaei"}],"key":"gSig8GYJi5"},{"type":"heading","depth":2,"position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"Acknowledgements","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"GP2hSoUIZL"}],"identifier":"acknowledgements","label":"Acknowledgements","html_id":"acknowledgements","implicit":true,"key":"AM409lOpIk"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"This work was supported by the European Research Council (ERC project WOLF)\nand by the French government under the management of Agence Nationale de la\nRecherche as part of the “France 2030” program, reference ANR-23-IACL-0008\n(PRAIRIE-PSAI).","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"rTfdhN5yOs"}],"key":"IersTyZaum"}],"key":"bUOMuDMnrK"}],"key":"Bb05qpKRCu"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Generative Models via Transportation","url":"/transportation-models","group":"Chapters"},"next":{"title":"Notation Table","url":"/notation-table","group":"Chapters"}}},"domain":"http://localhost:3000"}