\usepackage{float}
\definecolor{algorithmrule}{HTML}{6D7D8C}
\makeatletter
\newcommand{\otalgrule}[1]{%
	\begingroup\color{algorithmrule}\hrule height #1\relax\endgroup%
}
\newcommand\fs@otruled{%
	\def\@fs@cfont{\bfseries}%
	\let\@fs@capt\floatc@ruled
	\def\@fs@pre{\otalgrule{.65pt}\kern2.5pt}%
	\def\@fs@mid{\kern2pt\otalgrule{.35pt}\kern3pt}%
	\def\@fs@post{\kern2.5pt\otalgrule{.65pt}\relax}%
	\let\@fs@iftopcapt\iftrue%
}
\makeatother
\floatstyle{otruled}
\newfloat{algfloat}{tbp}{loa}[chapter]
\floatname{algfloat}{Algorithm}
\definecolor{algorithmblockrule}{HTML}{B7C0C8}
