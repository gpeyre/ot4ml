	backgroundcolor=white,
	linecolor=algorithmblockrule,
	linewidth=.45pt,
	topline=false,
	rightline=false,
	bottomline=false,
	innerleftmargin=7pt,
	innerrightmargin=0pt,
	innertopmargin=0pt,
	innerbottommargin=0pt,
