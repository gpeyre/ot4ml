	after skip=.45\baselineskip,
	overlay unbroken={\ottcbwavyframe{examplegoldbar}},
	overlay first={\ottcbwavyframe{examplegoldbar}},
	overlay middle={\ottcbwavyframe{examplegoldbar}},
	overlay last={\ottcbwavyframe{examplegoldbar}},
}
\newtheoremstyle{smalltheexample}
	{0pt}
