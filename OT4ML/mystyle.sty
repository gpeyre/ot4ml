\newlength{\otfigurecaptionmargin}
\setlength{\otfigurecaptionmargin}{1.1em}
\newlength{\otfigurecaptionaboveskip}
\setlength{\otfigurecaptionaboveskip}{3pt}
\makeatletter
\def\ot@figuretype{figure}
\def\ot@algtype{algfloat}
\long\def\@makecaption#1#2{%
	\ifx\@captype\ot@figuretype
		\vskip\otfigurecaptionaboveskip
		\begingroup
		\small
		\noindent\hspace*{\otfigurecaptionmargin}%
		\parbox[t]{\dimexpr\hsize-2\otfigurecaptionmargin\relax}{%
			\raggedright{\itshape #1:} #2\par
		}%
		\endgroup
	\else
		\ifx\@captype\ot@algtype
			\vskip 2pt
			\begingroup
			\small
			\noindent{\bfseries #1:} {\itshape #2}\par
			\endgroup
			\vskip 2pt
		\else
			\vskip\abovecaptionskip
			\sbox\@tempboxa{#1: #2}%
			\ifdim \wd\@tempboxa >\hsize
				#1: #2\par
			\else
				\global \@minipagefalse
				\hb@xt@\hsize{\hfil\box\@tempboxa\hfil}%
			\fi
			\vskip\belowcaptionskip
		\fi
	\fi
}
\makeatother

