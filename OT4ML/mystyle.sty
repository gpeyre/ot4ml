\newcommand{\ottcbwavyframe}[1]{%
	\draw[
		#1,
		line width=.9pt,
		decorate,
		decoration={snake, amplitude=.45pt, segment length=3.4pt}
	] ([xshift=.5pt]frame.north west) -- ([xshift=.5pt]frame.south west);%
}
\newtcolorbox{otremarkbox}{%
	enhanced,
	breakable,
	blanker,
	left=10pt,
	right=0pt,
	top=1pt,
	bottom=1pt,
	before skip=.45\baselineskip,
	after skip=.45\baselineskip,
	borderline west={.9pt}{0pt}{remarkbluebar},
}
\newtheoremstyle{waveremark}
	{0pt}
	{0pt}
	{\normalfont}
	{}
	{\bfseries\color{black!70}}
