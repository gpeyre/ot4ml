\@writefile{lof}{\contentsline {figure}{\numberline {7.12}{\ignorespaces Soft Legendre biconjugates as approximations of lower convex envelopes. In each panel, the dashed gray curve is a non-convex function $f$, the red curve is the hard biconjugate $f^{**}$, and the purple-to-blue curves show $(f^{*,\varepsilon })^{*,\varepsilon }$ for increasing $\varepsilon $. The pale gray area marks the part of $f$ lying above its convex envelope, which is progressively filled in by the soft convexification.}}{116}{figure.7.12}\protected@file@percent }
\newlabel{fig:sinkhorn-soft-biconjugates}{{7.12}{116}{Soft Legendre biconjugates as approximations of lower convex envelopes. In each panel, the dashed gray curve is a non-convex function $f$, the red curve is the hard biconjugate $f^{**}$, and the purple-to-blue curves show $(f^{*,\epsilon })^{*,\epsilon }$ for increasing $\epsilon $. The pale gray area marks the part of $f$ lying above its convex envelope, which is progressively filled in by the soft convexification}{figure.7.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.13}{\ignorespaces Hopf--Cole numerics for viscous Hamilton--Jacobi and Burgers dynamics in one dimension. Each panel fixes $\varepsilon $ and evolves the same initial Gaussian-shaped Burgers velocity. The upper curves show the potential $\varphi _t$ obtained from the heat solution by $\varphi _t=-\varepsilon \qopname  \relax o{log}u_t$, while the lower curves show the Burgers velocity $v_t=\partial _x\varphi _t=-\varepsilon \,\partial _x\qopname  \relax o{log}u_t$. Colors encode time from red to blue; small $\varepsilon $ lets the Gaussian bump develop a sharp shock-like front, while larger $\varepsilon $ gives stronger heat smoothing and viscous damping.}}{116}{figure.7.13}\protected@file@percent }
\newlabel{fig:sinkhorn-hopf-cole-transform}{{7.13}{116}{Hopf--Cole numerics for viscous Hamilton--Jacobi and Burgers dynamics in one dimension. Each panel fixes $\epsilon $ and evolves the same initial Gaussian-shaped Burgers velocity. The upper curves show the potential $\phi _t$ obtained from the heat solution by $\phi _t=-\epsilon \log u_t$, while the lower curves show the Burgers velocity $v_t=\partial _x\phi _t=-\epsilon \,\partial _x\log u_t$. Colors encode time from red to blue; small $\epsilon $ lets the Gaussian bump develop a sharp shock-like front, while larger $\epsilon $ gives stronger heat smoothing and viscous damping}{figure.7.13}{}}
