\@writefile{lof}{\contentsline {figure}{\numberline {4.5}{\ignorespaces Discrete $c$-transform as a lower envelope for costs $c_p(x,y)=|x-y|^p$. The red circles are four source atoms $x_i$ with potential values $f_i$; the gray curves are the translated functions $y\DOTSB \mapstochar \rightarrow c_p(x_i,y)-f_i$; the colored curve is their lower envelope $f^c(y)=\qopname  \relax m{min}_i c_p(x_i,y)-f_i$. This is the semi-discrete situation where $\mathcal  {X}$ is finite, equivalently the source measure $\alpha $ is discrete; Chapter\nobreakspace  {}\ref  {sec-semidiscr-w1} studies the complementary case where the eliminated potential is supported on finitely many target atoms.}}{69}{figure.4.5}\protected@file@percent }
\newlabel{fig:dual-c-transform-envelope}{{4.5}{69}{Discrete $c$-transform as a lower envelope for costs $c_p(x,y)=|x-y|^p$. The red circles are four source atoms $x_i$ with potential values $f_i$; the gray curves are the translated functions $y\mapsto c_p(x_i,y)-f_i$; the colored curve is their lower envelope $f^c(y)=\min _i c_p(x_i,y)-f_i$. This is the semi-discrete situation where $\X $ is finite, equivalently the source measure $\al $ is discrete; Chapter~\ref {sec-semidiscr-w1} studies the complementary case where the eliminated potential is supported on finitely many target atoms}{figure.4.5}{}}
