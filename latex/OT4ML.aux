\@writefile{lof}{\contentsline {figure}{\numberline {10.5}{\ignorespaces Capacity-constrained entropic OT between two one-dimensional Gaussian-mixture histograms. Each matrix solves\nobreakspace  {}\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq-entropic-capacity-constrained-ot}\unskip \@@italiccorr )}} with the same marginals and the same squared-distance cost. The left panel is the unconstrained entropic OT solution, corresponding to the density-ratio cap $U_{ij}=+\infty $. The other panels impose $U_{ij}=\kappa a_i b_j$. The red side strip is the source marginal and the blue top strip is the target marginal. As the capacity decreases, more entries saturate and the coupling is forced to spread.}}{178}{figure.10.5}\protected@file@percent }
\newlabel{fig:capacity-constrained-ot-1d}{{10.5}{178}{Capacity-constrained entropic OT between two one-dimensional Gaussian-mixture histograms. Each matrix solves~\eqref {eq-entropic-capacity-constrained-ot} with the same marginals and the same squared-distance cost. The left panel is the unconstrained entropic OT solution, corresponding to the density-ratio cap $U_{ij}=+\infty $. The other panels impose $U_{ij}=\kappa a_i b_j$. The red side strip is the source marginal and the blue top strip is the target marginal. As the capacity decreases, more entries saturate and the coupling is forced to spread}{figure.10.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10.6}{\ignorespaces Capacity-constrained local self-couplings on a two-dimensional empirical Gaussian mixture. The source and target are the same semi-regular uniform empirical measure on $n$ atoms, but the diagonal is removed to avoid the trivial identity plan and reveal the local graph selected by the capped problem. Each panel solves\nobreakspace  {}\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq-entropic-capacity-constrained-ot}\unskip \@@italiccorr )}} with the off-diagonal cap $U_{ij}=1/(qn)$, equivalently $P_{ij}/a_i\leqslant 1/q$ since $a_i=1/n$. The three panels therefore impose at least one, three and five outgoing connections per source atom; increasing $q$ forces the local matching to spread over more neighbors.}}{179}{figure.10.6}\protected@file@percent }
\newlabel{fig:capacity-constrained-ot-2d}{{10.6}{179}{Capacity-constrained local self-couplings on a two-dimensional empirical Gaussian mixture. The source and target are the same semi-regular uniform empirical measure on $n$ atoms, but the diagonal is removed to avoid the trivial identity plan and reveal the local graph selected by the capped problem. Each panel solves~\eqref {eq-entropic-capacity-constrained-ot} with the off-diagonal cap $U_{ij}=1/(qn)$, equivalently $P_{ij}/a_i\leq 1/q$ since $a_i=1/n$. The three panels therefore impose at least one, three and five outgoing connections per source atom; increasing $q$ forces the local matching to spread over more neighbors}{figure.10.6}{}}
