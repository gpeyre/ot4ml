\@writefile{lof}{\contentsline {figure}{\numberline {22}{\ignorespaces Discrete Kantorovich dual potentials for the quadratic cost $C_{i,j}=|x_i-y_j|^2$. In each panel the upper strip shows the fixed source histogram in red and the target histogram in blue. The lower strip shows an optimal pair of dual vectors $(\mathrm  {f},\mathrm  {g})$, with gauge chosen so that $\langle \mathrm  {f},\,\mathrm  {a}\rangle =0$. Complementary slackness states that mass can be transported only through entries where $\mathrm  {f}_i+\mathrm  {g}_j=C_{i,j}$.}}{41}{figure.5.22}\protected@file@percent }
\newlabel{fig:dual-kantorovich-discrete-potentials}{{22}{41}{Discrete Kantorovich dual potentials for the quadratic cost $C_{i,j}=|x_i-y_j|^2$. In each panel the upper strip shows the fixed source histogram in red and the target histogram in blue. The lower strip shows an optimal pair of dual vectors $(\fD ,\gD )$, with gauge chosen so that $\dotp {\fD }{\a }=0$. Complementary slackness states that mass can be transported only through entries where $\fD _i+\gD _j=C_{i,j}$}{figure.5.22}{}}
