\@writefile{lof}{\contentsline {figure}{\numberline {58}{\ignorespaces Attention as a transportation dynamics on token measures. The schematic uses the attractive setup $Q=K=I$ and velocity $W(X)X-X$, where $W(X)$ is the softmax attention matrix. The left panel shows one layer: faint violet edges encode attention weights and gray arrows show the residual velocity applied to red tokens. The right panel follows the same tokens through residual depth, colored from red to blue, and shows local clustering induced by attention.}}{104}{figure.14.58}\protected@file@percent }
\newlabel{fig:transformer-token-measure-flow}{{58}{104}{Attention as a transportation dynamics on token measures. The schematic uses the attractive setup $Q=K=I$ and velocity $W(X)X-X$, where $W(X)$ is the softmax attention matrix. The left panel shows one layer: faint violet edges encode attention weights and gray arrows show the residual velocity applied to red tokens. The right panel follows the same tokens through residual depth, colored from red to blue, and shows local clustering induced by attention}{figure.14.58}{}}
\@writefile{toc}{\contentsline {paragraph}{Gradient structure and limitations.}{104}{section*.93}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {14.4}Flows over the Gaussian Manifold}{104}{subsection.14.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {59}{\ignorespaces Gaussian closures of transport dynamics between two overlapping anisotropic Gaussians. The left panel is the exact $W_2$ Gaussian geodesic. The middle panel shows a regularized Sinkhorn-style closure, where the same mean path is accompanied by inflated intermediate covariances. The right panel shows a drifting-style closure with a curved mean path and moment-matched covariance ellipses. These finite-dimensional pictures keep only means and covariances, and therefore discard higher-order shape information that would be created by a genuinely nonlinear velocity field.}}{105}{figure.14.59}\protected@file@percent }
\newlabel{fig:gradflow-gaussian-closure}{{59}{105}{Gaussian closures of transport dynamics between two overlapping anisotropic Gaussians. The left panel is the exact $W_2$ Gaussian geodesic. The middle panel shows a regularized Sinkhorn-style closure, where the same mean path is accompanied by inflated intermediate covariances. The right panel shows a drifting-style closure with a curved mean path and moment-matched covariance ellipses. These finite-dimensional pictures keep only means and covariances, and therefore discard higher-order shape information that would be created by a genuinely nonlinear velocity field}{figure.14.59}{}}
