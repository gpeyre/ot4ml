\@writefile{lof}{\contentsline {figure}{\numberline {14.2}{\ignorespaces One-dimensional diffusion bridge for a Gaussian-mixture data law. The forward path $Z_t=(1-t)X+tY$ smooths the red data density toward a blue Gaussian endpoint. Reversing the probability-flow ODE transports a denser set of blue noise samples back toward the data modes, making the splitting of trajectories across mixture components visible.}}{146}{figure.14.2}\protected@file@percent }
\newlabel{fig:generative-diffusion-1d-forward-backward}{{14.2}{146}{One-dimensional diffusion bridge for a Gaussian-mixture data law. The forward path $Z_t=(1-t)X+tY$ smooths the red data density toward a blue Gaussian endpoint. Reversing the probability-flow ODE transports a denser set of blue noise samples back toward the data modes, making the splitting of trajectories across mixture components visible}{figure.14.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14.3}{\ignorespaces Two-dimensional noising path from three Dirac masses to a single Gaussian. The interpolation $Z_t=(1-t)X+tY$ starts from three red atoms and progressively turns them into Gaussian components whose centers move toward the origin and whose covariance grows like $(t\sigma )^2\mathrm  {Id}$. At $t=1$ the three components coincide, giving the blue centered Gaussian endpoint.}}{147}{figure.14.3}\protected@file@percent }
\newlabel{fig:generative-diffusion-2d-forward-backward}{{14.3}{147}{Two-dimensional noising path from three Dirac masses to a single Gaussian. The interpolation $Z_t=(1-t)X+tY$ starts from three red atoms and progressively turns them into Gaussian components whose centers move toward the origin and whose covariance grows like $(t\sigma )^2\Id $. At $t=1$ the three components coincide, giving the blue centered Gaussian endpoint}{figure.14.3}{}}
