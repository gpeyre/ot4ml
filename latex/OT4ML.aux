\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces One-dimensional optimal matching by quantile sorting. The red and blue curves are smooth laws used to generate equal-weight empirical measures; the dots are inverse-CDF samples at common quantile levels. The monotone assignment connects equal ranks, both for two Gaussian mixtures and for the transport from one central Gaussian toward a three-mode target law.}}{3}{figure.1.1}\protected@file@percent }
\newlabel{fig:matching-1d-quantile-assignment}{{1}{3}{One-dimensional optimal matching by quantile sorting. The red and blue curves are smooth laws used to generate equal-weight empirical measures; the dots are inverse-CDF samples at common quantile levels. The monotone assignment connects equal ranks, both for two Gaussian mixtures and for the transport from one central Gaussian toward a three-mode target law}{figure.1.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Histogram equalization as one-dimensional Monge transport on pixel intensities. The map is the monotone rearrangement $T=Q_\beta \circ F_\alpha $, using the cumulative and quantile functions defined later in Definition\nobreakspace  {}\ref  {def-cdf-quantile}. The images are interpolated pointwise by $I_t=(1-t)I+tT(I)$, and the histograms show the empirical laws of these interpolated intensities; they are not binwise linear interpolations of histograms. This is the one-dimensional version of McCann displacement interpolation, discussed in Section\nobreakspace  {}\ref  {sec-monge-interpolation}.}}{3}{figure.1.2}\protected@file@percent }
\newlabel{fig:monge-histogram-equalization}{{2}{3}{Histogram equalization as one-dimensional Monge transport on pixel intensities. The map is the monotone rearrangement $T=Q_\beta \circ F_\alpha $, using the cumulative and quantile functions defined later in Definition~\ref {def-cdf-quantile}. The images are interpolated pointwise by $I_t=(1-t)I+tT(I)$, and the histograms show the empirical laws of these interpolated intensities; they are not binwise linear interpolations of histograms. This is the one-dimensional version of McCann displacement interpolation, discussed in Section~\ref {sec-monge-interpolation}}{figure.1.2}{}}
