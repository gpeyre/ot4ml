\@writefile{lof}{\contentsline {figure}{\numberline {9.5}{\ignorespaces Linear OT coordinates. Fixing a reference measure $\rho $ turns each target into a map $T_\alpha $ from $\rho $ to $\alpha $, or equivalently into the displacement field $T_\alpha -\mathrm  {Id}$. In one dimension this is exactly the quantile parametrization of $\Wass  _2$, so averaging the maps toward a two-component $\alpha $ and a two-component $\beta $ gives the true Wasserstein barycenter. In two dimensions, the first panel shows the reference-to-target maps, computed on dense clouds and displayed on farthest-point subsets, with $\beta $ represented by two Gaussian components. The middle purple panel shows the linearized barycenter obtained by averaging the two maps from $\rho $. The right purple panel shows the genuine McCann midpoint between $\alpha $ and $\beta $, obtained by solving a direct OT problem between the two target clouds and interpolating at $t=1/2$.}}{121}{figure.9.5}\protected@file@percent }
\newlabel{fig:dualnorms-linear-ot-embedding}{{9.5}{121}{Linear OT coordinates. Fixing a reference measure $\rho $ turns each target into a map $T_\alpha $ from $\rho $ to $\alpha $, or equivalently into the displacement field $T_\alpha -\Id $. In one dimension this is exactly the quantile parametrization of $\Wass _2$, so averaging the maps toward a two-component $\alpha $ and a two-component $\beta $ gives the true Wasserstein barycenter. In two dimensions, the first panel shows the reference-to-target maps, computed on dense clouds and displayed on farthest-point subsets, with $\beta $ represented by two Gaussian components. The middle purple panel shows the linearized barycenter obtained by averaging the two maps from $\rho $. The right purple panel shows the genuine McCann midpoint between $\alpha $ and $\beta $, obtained by solving a direct OT problem between the two target clouds and interpolating at $t=1/2$}{figure.9.5}{}}
\newlabel{prop-linear-ot-stability}{{9.12}{121}{Local stability of linear OT}{thm.9.3.12}{}}
