\newlabel{fig:dual-kantorovich-continuous-potentials}{{4.3}{68}{Continuous Kantorovich potentials for the same source and target families as Figure~\ref {fig:dual-kantorovich-discrete-potentials}. The upper strips show the source density $\al $ in red and the target density $\be $ in blue, including the strongly shifted and three-mode targets. The lower strips show potentials $f$ and $g=f^c$ for the quadratic cost $c(x,y)=|x-y|^2$, with the same gauge convention as in the discrete figure. The equality set $f(x)+g(y)=c(x,y)$ contains the monotone transport graph}{figure.4.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.4}{\ignorespaces Complementary slackness contacts for one-dimensional quadratic OT. Left: transport between two Gaussian densities. Right: transport between two-component Gaussian-mixture densities. Each central heatmap displays the nonnegative dual slack $s(x,y)=|x-y|^2-f(x)-g(y)$: pale colors mark the contact valley and darker blue means larger strict slack. The red top strip and blue side strip show the source and target densities. The violet curve is the quantile transport contact graph $(x,T(x))$, where $s(x,T(x))=0$ and the optimal Monge plan is supported.}}{68}{figure.4.4}\protected@file@percent }
\newlabel{fig:dual-complementary-slackness-contacts}{{4.4}{68}{Complementary slackness contacts for one-dimensional quadratic OT. Left: transport between two Gaussian densities. Right: transport between two-component Gaussian-mixture densities. Each central heatmap displays the nonnegative dual slack $s(x,y)=|x-y|^2-f(x)-g(y)$: pale colors mark the contact valley and darker blue means larger strict slack. The red top strip and blue side strip show the source and target densities. The violet curve is the quantile transport contact graph $(x,T(x))$, where $s(x,T(x))=0$ and the optimal Monge plan is supported}{figure.4.4}{}}
