\@writefile{lof}{\contentsline {figure}{\numberline {12.4}{\ignorespaces \emph  {Discrete Wasserstein distances on small Markov-chain simplices.} Left: the closed-form profiles \(p\DOTSB \mapstochar \rightarrow \mathcal  W_K(a_p,a_{p_0})\), with \(a_p=(p,1-p)\), for several anchors \(p_0\) on \(\Sigma _2\). Middle: numerical level sets of \(\mathcal  W_K(a,\bar  a)\) on \(\Sigma _3\), where \(\bar  a=(1/3,1/3,1/3)\), computed from the local Riemannian norm induced by the complete-neighbor Markov chain. Right: the corresponding level sets for the ordinary \(W_2\) distance with \(d(i,j)=1\) for \(i\neq j\), i.e. \(W_2^2(a,\bar  a)=|\!| a-\bar  a |\!|_{\mathrm  {TV}}\).}}{210}{figure.12.4}\protected@file@percent }
\newlabel{fig:discrete-markov-simplex-distances}{{12.4}{210}{\emph {Discrete Wasserstein distances on small Markov-chain simplices.} Left: the closed-form profiles \(p\mapsto \mathcal W_K(a_p,a_{p_0})\), with \(a_p=(p,1-p)\), for several anchors \(p_0\) on \(\Sigma _2\). Middle: numerical level sets of \(\mathcal W_K(a,\bar a)\) on \(\Sigma _3\), where \(\bar a=(1/3,1/3,1/3)\), computed from the local Riemannian norm induced by the complete-neighbor Markov chain. Right: the corresponding level sets for the ordinary \(W_2\) distance with \(d(i,j)=1\) for \(i\neq j\), i.e. \(W_2^2(a,\bar a)=\norm {a-\bar a}_{\mathrm {TV}}\)}{figure.12.4}{}}
