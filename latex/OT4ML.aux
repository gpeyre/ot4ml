\@writefile{lof}{\contentsline {figure}{\numberline {7.5}{\ignorespaces KL-normalized Sinkhorn dual potentials along the scaling iteration for the same one-dimensional Gaussian-mixture setting as Figure\nobreakspace  {}\ref  {fig:sinkhorn-dual-potentials-epsilon}, with fixed regularization strength $\varepsilon =0.045$. The bottom silhouettes show both the source histogram $\mathrm  {a}$ in red and the target histogram $\mathrm  {b}$ in blue, while the red and blue curves are the logarithmic scaling potentials. All panels share the same axes, making stabilization visible.}}{70}{figure.7.5}\protected@file@percent }
\newlabel{fig:sinkhorn-potentials-iterations}{{7.5}{70}{KL-normalized Sinkhorn dual potentials along the scaling iteration for the same one-dimensional Gaussian-mixture setting as Figure~\ref {fig:sinkhorn-dual-potentials-epsilon}, with fixed regularization strength $\epsilon =0.045$. The bottom silhouettes show both the source histogram $\a $ in red and the target histogram $\b $ in blue, while the red and blue curves are the logarithmic scaling potentials. All panels share the same axes, making stabilization visible}{figure.7.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.6}{\ignorespaces Marginal violation along Sinkhorn half-steps for four values of $\varepsilon $ on the same one-dimensional Gaussian-mixture problem, together with the corresponding limiting plans. The plotted error is $\frac  12(\|P_k\mathds  {1}-\mathrm  {a}\|_1+\|P_k^\top \mathds  {1}-\mathrm  {b}\|_1)$ on a logarithmic scale. The colored boxes on the right use the same colors as the convergence curves. For fixed positive $\varepsilon $, the curves enter a linear regime; smaller $\varepsilon $ gives a sharper transport geometry but a more peaked Gibbs kernel and slower scaling.}}{71}{figure.7.6}\protected@file@percent }
\newlabel{fig:sinkhorn-linear-rate-epsilon}{{7.6}{71}{Marginal violation along Sinkhorn half-steps for four values of $\epsilon $ on the same one-dimensional Gaussian-mixture problem, together with the corresponding limiting plans. The plotted error is $\frac 12(\|P_k\ones -\a \|_1+\|P_k^\top \ones -\b \|_1)$ on a logarithmic scale. The colored boxes on the right use the same colors as the convergence curves. For fixed positive $\epsilon $, the curves enter a linear regime; smaller $\epsilon $ gives a sharper transport geometry but a more peaked Gibbs kernel and slower scaling}{figure.7.6}{}}
