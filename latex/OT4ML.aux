\newlabel{fig:matching-1d-quantile-assignment}{{1.1}{3}{One-dimensional optimal matching by quantile sorting. The red and blue curves are smooth laws used to generate equal-weight empirical measures; the dots are inverse-CDF samples at common quantile levels. The monotone assignment connects equal ranks, both for two Gaussian mixtures and for the transport from one central Gaussian toward a three-mode target law}{figure.1.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1.2}{\ignorespaces Histogram equalization as one-dimensional Monge transport on pixel intensities. The map is the monotone rearrangement $T=Q_\beta \circ F_\alpha $, using the cumulative and quantile functions defined later in Definition\nobreakspace  {}\ref  {def-cdf-quantile}; here $\beta $ is a truncated Gaussian concentrated near dark intensities. The images are interpolated pointwise by $I_t=(1-t)I+tT(I)$, and all histograms share the same vertical scale to make the displacement of intensity mass comparable across time.}}{4}{figure.1.2}\protected@file@percent }
\newlabel{fig:monge-histogram-equalization}{{1.2}{4}{Histogram equalization as one-dimensional Monge transport on pixel intensities. The map is the monotone rearrangement $T=Q_\beta \circ F_\alpha $, using the cumulative and quantile functions defined later in Definition~\ref {def-cdf-quantile}; here $\beta $ is a truncated Gaussian concentrated near dark intensities. The images are interpolated pointwise by $I_t=(1-t)I+tT(I)$, and all histograms share the same vertical scale to make the displacement of intensity mass comparable across time}{figure.1.2}{}}
